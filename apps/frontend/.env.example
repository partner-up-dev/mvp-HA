# Fixed-port local fallback.
#
# The default repository-level development entry is `pnpm dev:portless`.
# In portless mode, PORTLESS_URL, HOST, and PORT are injected by portless and
# Vite derives the frontend origin from PORTLESS_URL.
#
# Use the values below only for explicit fixed-port local work.
VITE_PORT=4001
VITE_API_URL=http://localhost:4001 # Vite dev server proxies /api to backend.
VITE_HOST=
VITE_BACKEND_HOST=localhost
VITE_BACKEND_PORT=4002
VITE_BACKEND_PROXY_TARGET=
VITE_USE_MOCK=false
VITE_WECHAT_ABILITY_MOCKING_ENABLED=false
