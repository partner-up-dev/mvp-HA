{
  "name": "partner-up-dev",
  "private": true,
  "packageManager": "pnpm@10.28.1",
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "dev": "pnpm --filter @partner-up-dev/frontend dev & pnpm --filter @partner-up-dev/backend dev",
    "dev:portless": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/portless.ps1",
    "dev:portless:frontend": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/portless.ps1 --name partner-up -- pnpm --filter @partner-up-dev/frontend dev",
    "dev:portless:backend": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/portless.ps1 --name api.partner-up -- pnpm --filter @partner-up-dev/backend dev",
    "dev:frontend": "pnpm --filter @partner-up-dev/frontend dev",
    "dev:backend": "pnpm --filter @partner-up-dev/backend dev",
    "build:frontend": "pnpm --filter @partner-up-dev/frontend build",
    "build:backend": "pnpm --filter @partner-up-dev/backend build",
    "build": "pnpm --filter @partner-up-dev/backend build && pnpm --filter @partner-up-dev/frontend build",
    "test:backend:unit": "pnpm --filter @partner-up-dev/backend test:unit",
    "test:scenario": "node scripts/run-scenario-tests.mjs",
    "test:scenario:system": "tsx tests/scenario/run-scenario-tests.mts",
    "db:generate": "pnpm --filter @partner-up-dev/backend db:generate",
    "db:lint": "pnpm --filter @partner-up-dev/backend db:lint",
    "db:migrate": "pnpm --filter @partner-up-dev/backend db:migrate",
    "db:reset": "pnpm --filter @partner-up-dev/backend db:reset",
    "db:seed": "pnpm --filter @partner-up-dev/backend db:seed",
    "db:next-migration": "pnpm --filter @partner-up-dev/backend db:next-migration",
    "db:studio": "pnpm --filter @partner-up-dev/backend db:studio"
  },
  "devDependencies": {
    "@hono/node-server": "^1.19.9",
    "playwright": "^1.59.1",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vite": "^6.4.1"
  }
}
